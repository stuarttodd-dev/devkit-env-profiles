#!/usr/bin/env php
<?php

declare(strict_types=1);

$autoload = dirname(__DIR__) . '/vendor/autoload.php';
if (!is_file($autoload)) {
    $autoload = dirname(__DIR__, 4) . '/autoload.php';
}
if (!is_file($autoload)) {
    fwrite(STDERR, "Composer autoload not found. Run composer install.\n");
    exit(2);
}

require $autoload;

use Devkit\Env\Cli\MainRouter;

exit((new MainRouter())->run($argv));
