{
    "name": "devkit/env-diff",
    "description": "Compare .env files across environments — missing keys, extras, and value drift — with optional masking.",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Devkit\\EnvDiff\\": "src/"
        }
    },
    "authors": [
        {
            "name": "Stuart Todd"
        }
    ],
    "minimum-stability": "stable",
    "require": {
        "php": "^8.3",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "pestphp/pest": "^3.0",
        "phpmd/phpmd": "^2.15",
        "phpstan/phpstan": "^1.12",
        "rector/rector": "^1.2",
        "squizlabs/php_codesniffer": "^3.10"
    },
    "bin": [
        "bin/devkit-env-diff"
    ],
    "scripts": {
        "tests": "./vendor/bin/pest",
        "phpcs": "./vendor/bin/phpcs --standard=PSR12 --report=summary src/ bin/",
        "phpcbf": "./vendor/bin/phpcbf --standard=PSR12 src/ bin/",
        "phpmd": "./vendor/bin/phpmd src/ text cleancode,codesize,controversial,design,naming,unusedcode",
        "phpstan": "./vendor/bin/phpstan analyse src/ bin/ --level max",
        "rector:dry-run": "./vendor/bin/rector process --dry-run",
        "rector": "./vendor/bin/rector process",
        "standards:check": [
            "@phpcs",
            "@phpmd",
            "@phpstan",
            "@rector:dry-run"
        ],
        "standards:fix": [
            "@phpcbf",
            "@rector"
        ]
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
